# Node.js server port (Hostinger sets this automatically)
PORT=3000

# MySQL Database — set these in Hostinger hPanel → Node.js → Environment Variables
# Leave blank during local development to use localStorage-only mode
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=

# (Legacy — no longer used; kept for reference)
# GEMINI_API_KEY=
# APP_URL=
